<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<array>
    <dict>
        <key>cell</key>
        <string>PSGroupCell</string>
        <key>label</key>
        <string>Features</string>
        <key>footerText</key>
        <string>The floating K4L button opens Gallery Upload, Files, Media Vault, and in-app diagnostics.</string>
    </dict>
    <dict>
        <key>cell</key>
        <string>PSSwitchCell</string>
        <key>label</key>
        <string>Gallery Upload</string>
        <key>defaults</key>
        <string>com.p6ycode.k4lsnap</string>
        <key>key</key>
        <string>galleryUploadEnabled</string>
        <key>default</key>
        <true/>
        <key>PostNotification</key>
        <string>com.p6ycode.k4lsnap/reload</string>
    </dict>
    <dict>
        <key>cell</key>
        <string>PSSwitchCell</string>
        <key>label</key>
        <string>Floating Launcher</string>
        <key>defaults</key>
        <string>com.p6ycode.k4lsnap</string>
        <key>key</key>
        <string>launcherEnabled</string>
        <key>default</key>
        <true/>
        <key>PostNotification</key>
        <string>com.p6ycode.k4lsnap/reload</string>
    </dict>
    <dict>
        <key>cell</key>
        <string>PSGroupCell</string>
        <key>label</key>
        <string>Media Preparation</string>
        <key>footerText</key>
        <string>Images support rotation, center crop, and resize. Videos support trim ranges, export quality selection, and poster-frame thumbnails. Caption, account, friend, and category metadata are stored in the vault.</string>
    </dict>
    <dict>
        <key>cell</key>
        <string>PSGroupCell</string>
        <key>label</key>
        <string>Storage</string>
        <key>footerText</key>
        <string>Vault browsing, search, thumbnails, preview, metadata editing, export, deletion, pending-draft status, and storage diagnostics are available from the in-app launcher.</string>
    </dict>
    <dict>
        <key>cell</key>
        <string>PSGroupCell</string>
        <key>footerText</key>
        <string>K4LSnap 0.2.0</string>
    </dict>
</array>
</plist>
